# ============================================================================
# Backend configuration — copy to `.env` and adjust.
# ============================================================================

# --- General ---
APP_NAME="Pathology SaaS"
ENV=development                      # development | production

# --- Database ---
# SQLite (default, zero-config). For production use PostgreSQL, e.g.:
#   DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/pathology
DATABASE_URL=sqlite:///./pathology.db

# --- Auth / JWT ---
# CHANGE THIS in any non-local environment (used to sign session tokens).
SECRET_KEY=dev-secret-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=10080    # 7 days
JWT_ALGORITHM=HS256

# --- Google Sign-In ---
# OAuth 2.0 "Web application" Client ID from Google Cloud Console.
# Authorized JavaScript origin must include your frontend URL (e.g. http://localhost:5173).
# Leave empty to use dev login only.
GOOGLE_CLIENT_ID=

# Local convenience login (email only, no Google). MUST be false in production.
ALLOW_DEV_LOGIN=true

# --- Storage ---
# Where uploaded .svs files are written (local filesystem driver).
STORAGE_DIR=./storage
MAX_UPLOAD_BYTES=5368709120          # 5 GB

# --- WSI tiling ---
DEEPZOOM_TILE_SIZE=254
DEEPZOOM_OVERLAP=1
DEEPZOOM_FORMAT=jpeg                 # jpeg | png
DEEPZOOM_JPEG_QUALITY=80
SLIDE_CACHE_SIZE=8

# --- CORS (comma-separated frontend origins) ---
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
