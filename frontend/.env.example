# Frontend configuration — copy to `.env` and adjust.

# Base URL for the backend API.
# - Dev (default): leave as /api and let Vite proxy to the backend.
# - Prod: set to the full backend origin, e.g. https://api.yourdomain.com/api
VITE_API_BASE_URL=/api

# Where the Vite dev proxy forwards /api (dev only).
VITE_PROXY_TARGET=http://localhost:8000
